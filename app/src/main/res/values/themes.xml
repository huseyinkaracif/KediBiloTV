<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KediTV" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/neon_background</item>
        <item name="android:statusBarColor">@color/neon_background</item>
        <item name="android:navigationBarColor">@color/neon_background</item>
    </style>

    <style name="Theme.KediTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/neon_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.KediTV</item>
    </style>
</resources>
